APP_NAME="Voltrune"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
ROOT_DOMAIN=127.0.0.1
HUB_DOMAIN=hub.voltrune.com
HUB_URL=http://127.0.0.1:8000/hub
SOLAR_DOMAIN=
SOLAR_URL=http://127.0.0.1:8000/solar

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
SESSION_CONNECTION=sqlite
DB_CACHE_CONNECTION=sqlite
DB_QUEUE_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

# Local (app na sua maquina): usar o host remoto do banco na Hostoo
HUB_DB_HOST=108.181.92.72
# Producao (app na Hostoo): usar localhost
# HUB_DB_HOST=localhost
HUB_DB_PORT=3306
HUB_DB_DATABASE=voltrune_hub
HUB_DB_USERNAME=your_hub_db_user
HUB_DB_PASSWORD=your_hub_db_password
# Solar segue o mesmo padrao: local usa host remoto; producao pode usar localhost
SOLAR_DB_HOST=108.181.92.72
# SOLAR_DB_HOST=localhost
SOLAR_DB_PORT=3306
SOLAR_DB_DATABASE=voltrune_solar
SOLAR_DB_USERNAME=your_solar_db_user
SOLAR_DB_PASSWORD=your_solar_db_password
VOLTRUNE_ADMIN_EMAILS=caio@example.com
VOLTRUNE_ADMIN_NAME="Voltrune Admin"
VOLTRUNE_ADMIN_EMAIL=admin@voltrune.com
VOLTRUNE_ADMIN_PASSWORD=change_me_now
VOLTRUNE_ADMIN_COMPANY_NAME="Voltrune"
VOLTRUNE_ADMIN_COMPANY_SLUG=voltrune
VOLTRUNE_ADMIN_COMPANY_STATUS=active

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=mail.voltrune.com
MAIL_PORT=465
MAIL_USERNAME=contato@voltrune.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="contato@voltrune.com"
MAIL_FROM_NAME="Voltrune"
CONTACT_INBOX_ADDRESS="contato@voltrune.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WHATSAPP_URL=https://wa.me/5511998479359
PORTAL_REDIRECT_URL=
GA_MEASUREMENT_ID=
META_PIXEL_ID=
